# Copy to .env and adjust paths (optional — CLI overrides env).

# Whisper model: tiny, base, small, medium, large, large-v2, large-v3
SPANISH_PHON_WHISPER_MODEL=base

# ASR text similarity thresholds (0–100 rapidfuzz token_sort_ratio scale)
SPANISH_PHON_ASR_WARN_THRESHOLD=72
SPANISH_PHON_ASR_REJECT_THRESHOLD=55

# Audio quality (HEURISTIC)
SPANISH_PHON_MIN_DURATION_SEC=0.8
SPANISH_PHON_MIN_RMS_DB=-45

# MFA pretrained identifiers or local paths (see README)
SPANISH_PHON_MFA_DICTIONARY=spanish_mfa
SPANISH_PHON_MFA_ACOUSTIC=spanish_mfa

# MFA alignment relaxation for single-file alignment (see README troubleshooting)
SPANISH_PHON_MFA_BEAM=10
SPANISH_PHON_MFA_RETRY_BEAM=120

# Optional extra args passed to `mfa align` (space-separated in shell; here unused — extend code if needed)
# SPANISH_PHON_MFA_EXTRA=

# Max localized errors in JSON output
SPANISH_PHON_MAX_LOCALIZED_ERRORS=10
